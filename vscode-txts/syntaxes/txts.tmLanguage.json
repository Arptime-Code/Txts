{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "txts",
  "scopeName": "source.txts",
  "fileTypes": ["txts"],
  "patterns": [
    {
      "include": "#comments"
    },
    {
      "include": "#strings"
    },
    {
      "include": "#library-names"
    },
    {
      "include": "#builtin-references"
    },
    {
      "include": "#colon-references"
    },
    {
      "include": "#library-references"
    },
    {
      "include": "#keywords"
    }
  ],
  "repository": {
    "comments": {
      "name": "comment.line.txts",
      "match": "^(?!\\s*(IMPORT|CALL|ADD|REPLACE)\\b).*$"
    },
    "strings": {
      "name": "string.quoted.double.txts",
      "begin": "\"",
      "end": "\"",
      "patterns": [
        {
          "name": "constant.character.escape.txts",
          "match": "\\\\.?"
        }
      ]
    },
    "library-names": {
      "match": "^\\s*\\b(IMPORT|CALL|ADD|REPLACE)\\s+([a-zA-Z_][a-zA-Z0-9_-]*)\\b(?![:\\.])",
      "captures": {
        "1": {
          "name": "keyword.control.txts"
        },
        "2": {
          "name": "support.class.txts"
        }
      }
    },
    "builtin-references": {
      "match": "\\b(txts)\\.(OUTPUT|CLEAR)\\b",
      "captures": {
        "1": {
          "name": "support.class.builtin.txts"
        },
        "2": {
          "name": "constant.language.txts"
        }
      }
    },
    "colon-references": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)(:)([a-zA-Z_][a-zA-Z0-9_-]*)(\\.([a-zA-Z_][a-zA-Z0-9_-]*))?\\b",
      "captures": {
        "1": {
          "name": "support.class.txts"
        },
        "2": {
          "name": "support.class.txts"
        },
        "3": {
          "name": "support.class.txts"
        },
        "4": {
          "name": "support.class.txts"
        },
        "5": {
          "name": "constant.other.txts"
        }
      }
    },
    "library-references": {
      "match": "\\b([a-zA-Z_][a-zA-Z0-9_-]*)\\.([a-zA-Z_][a-zA-Z0-9_-]*)\\b",
      "captures": {
        "1": {
          "name": "support.class.txts"
        },
        "2": {
          "name": "constant.other.txts"
        }
      }
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.import.txts",
          "match": "^\\s*\\b(IMPORT)\\b"
        },
        {
          "name": "keyword.control.call.txts",
          "match": "^\\s*\\b(CALL)\\b"
        },
        {
          "name": "keyword.control.add.txts",
          "match": "^\\s*\\b(ADD)\\b"
        },
        {
          "name": "keyword.control.replace.txts",
          "match": "^\\s*\\b(REPLACE)\\b"
        }
      ]
    }
  }
}
